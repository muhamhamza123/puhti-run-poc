Bootstrap: docker
From: python:3.11-slim

%post
    export TMPDIR=/scratch/project_2014823/tmp
    export PIP_NO_CACHE_DIR=1
    mkdir -p $TMPDIR

    pip install --no-cache-dir numpy pandas matplotlib ipykernel nbformat

    mkdir -p /app /output

%environment
    export PYTHONUNBUFFERED=1
    export MPLBACKEND=Agg

%labels
    Name test-container
    Version 1.0