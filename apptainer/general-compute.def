Bootstrap: docker
From: python:3.11-slim

%post
    export TMPDIR=/scratch/project_2014823/tmp
    export PIP_NO_CACHE_DIR=1
    mkdir -p $TMPDIR

    apt-get update -q && apt-get install -y --no-install-recommends \
        gcc g++ git curl libgeos-dev \
        && rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir \
        numpy \
        pandas \
        scipy \
        matplotlib \
        seaborn \
        scikit-learn \
        statsmodels \
        xarray \
        netCDF4 \
        requests \
        tqdm \
        joblib \
        influxdb-client \
        plotly \
        ipykernel \
        seaborn \
        nbformat

    mkdir -p /app /output

%environment
    export PYTHONUNBUFFERED=1
    export MPLBACKEND=Agg

%labels
    Name general-compute
    Version 2.0

%help
    General purpose Python 3.11 container for running user notebooks on Puhti.
    Pre-installed: numpy, pandas, scipy, matplotlib, seaborn, scikit-learn,
    statsmodels, xarray, netCDF4, requests, tqdm, influxdb-client, plotly.
    User requirements.txt installed at runtime for anything extra.
